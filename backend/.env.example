# ─── Server ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database (Amazon RDS MySQL) ─────────────────────────────────
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_NAME=clinic-db
DB_USER=admin
DB_PASSWORD=your_password_here

# ─── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# -----------------------------------
# AWS Configuration
# -----------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY=your_aws_access_key_id
AWS_SECRET_KEY=your_aws_secret_access_key

# -----------------------------------
# AWS S3 Settings
# -----------------------------------
S3_BUCKET_NAME=your-s3-bucket-name

# -----------------------------------
# Email Settings (Nodemailer)
# -----------------------------------
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password

# -----------------------------------
# AWS SNS Settings
# -----------------------------------
SNS_ENABLED=true
SNS_CLINIC_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:ClinicTopic

# ─── Jitsi (optional, defaults to https://meet.jit.si) ───────────
JITSI_BASE_URL=https://meet.jit.si

# ─── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or leave empty to allow all
ALLOWED_ORIGINS=http://localhost:3000
